    "news": [
    {
        "id": "1",
        "title": "DevLog #1 — Primeiros Passos",
        "date": "2026-05-08",
        "category": "DevLog",
        "content": "Olá aventureiros! Esta semana finalizamos a estrutura base do servidor. O sistema de classes RPG está em desenvolvimento, com 6 origens jogáveis previstas para o lançamento. O mapa de Notumbria já tem suas primeiras regiões construídas: a Cidade de Arenvhal, a Floresta de Mireth e as Ruínas do Antigo Reino. Fiquem ligados nas próximas atualizações!",
        "author": "Wesley — Dev Principal",
        "image": "https://i.pinimg.com/1200x/30/48/13/304813b44111c19602fd9152d1679ea9.jpg"
    }
],
"journal": [
    {
        "id": "1",
        "title": "A Queda das Estrelas Douradas",
        "date": "2026-05-08",
        "category": "Lore",
        "content": "Dizem os anciãos de Notumbria que há mil anos, quando os deuses ainda caminhavam entre os mortais, uma chuva de estrelas douradas caiu sobre as Planícies de Avel. Cada estrela que tocou o solo floresceu em um cristal de poder imenso — os chamados Fragmentos da Aurora. Guerreiros, magos e ladrões de toda a terra partiram em busca dessas relíquias. Poucos retornaram. Os que voltaram jamais falaram do que viram. Até hoje, os fragmentos permanecem escondidos, esperando por aqueles dignos o suficiente para carregá-los.",
        "author": "Cronista Real de Arenvhal",
        "image": "https://i.pinimg.com/736x/46/0e/ad/460eada6c67753772269de177a0bd53c.jpg"
    }
],
